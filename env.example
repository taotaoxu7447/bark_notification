# Copy this file to ~/.codex-watch-notifier/env and fill in at least one notification channel.
# Keep the real env file private: push tokens and webhook URLs are secrets.

# Bark, for iPhone / Apple Watch push notifications.
BARK_URL=
BARK_KEY=
BARK_LEVEL=timeSensitive
CODEX_BARK_ICON=https://raw.githubusercontent.com/taotaoxu7447/bark_notification/main/assets/codex-icon-large-v1.png
CODEX_BARK_GROUP=Codex
ZCODE_BARK_ICON=https://raw.githubusercontent.com/taotaoxu7447/bark_notification/main/assets/zcode-icon-v1.png
ZCODE_BARK_GROUP=ZCode

# ntfy, for Android phones / wearable notification forwarding.
# Public ntfy.sh topics are effectively shared secrets. Use a long random topic.
NTFY_URL=
NTFY_TOKEN=
NTFY_PRIORITY=default
NTFY_TAGS=computer,robot
# Optional per-tool override. Leave empty to reuse NTFY_URL.
CODEX_NTFY_URL=
CODEX_NTFY_TAGS=robot,computer
ZCODE_NTFY_URL=
ZCODE_NTFY_TAGS=zap,computer

# Optional channels. Leave empty unless explicitly needed.
CODEX_NOTIFY_WEBHOOK_URL=
WECOM_WEBHOOK_URL=
CODEX_NOTIFY_COMMAND=

# Runtime options.
CODEX_WATCH_MACOS_NOTIFICATION=0
CODEX_WATCH_POLL_INTERVAL=2
# Codex 5.6 may create many child agents. Keep their events silent by default.
# Set 1 only when you explicitly need notifications from every subagent.
CODEX_WATCH_NOTIFY_SUBAGENTS=0
# Skip old Codex completion events when rollout files are rewritten by account/session tools.
# Set 0 to disable. Default is 3600 seconds.
CODEX_WATCH_MAX_EVENT_AGE_SECONDS=3600
ZCODE_WATCH_ENABLED=1
ZCODE_WATCH_LOG_ROOT=~/.zcode/cli/log

# Privacy controls. Set to 0 for less sensitive notification bodies.
NOTIFY_INCLUDE_WORKSPACE=1
NOTIFY_INCLUDE_MESSAGE=1
NOTIFY_BODY_MAX_CHARS=1100
